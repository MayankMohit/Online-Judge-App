# Root .env — read by docker-compose for ${VAR} interpolation in docker-compose.yml.
# Copy to `.env` (gitignored) and fill in before deploying.

# Password for redis. When set, the redis container starts with --requirepass and
# the backend connects with it (redis://:PASSWORD@redis:6379). Leave unset/empty to
# run redis without auth (unchanged behavior). Redis is already isolated on an
# internal network, so this is defense-in-depth. Use a long random value, e.g.:
#   openssl rand -hex 32
REDIS_PASSWORD=
